APP_NAME="EliteShop"
APP_ENV=production
APP_KEY=base64:/jja5n36yeuLjwk67O/pGvjAGbVlrMumdF9joEYayM8=
APP_DEBUG=false
APP_URL=https://tu-dominio.com

LOG_CHANNEL=stack
LOG_LEVEL=error

# ─── Base de Datos (PC 4) ────────────────────────
DB_CONNECTION=mysql
DB_HOST=10.10.1.25
DB_PORT=3306
DB_DATABASE=scrum_proyecto_db
