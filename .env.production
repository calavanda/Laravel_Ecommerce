DB_PASSWORD=admin

# ─── Redis (PC 4) ────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=10.10.1.25
REDIS_PORT=6379
REDIS_PASSWORD=null

# ─── CRÍTICO: Sesión centralizada en Redis ───────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
CACHE_STORE=redis
QUEUE_CONNECTION=redis
BROADCAST_CONNECTION=redis
FILESYSTEM_DISK=local

